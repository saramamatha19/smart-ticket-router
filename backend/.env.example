# PostgreSQL connection string. Update user/password/host/port/db name
# to match your local or hosted PostgreSQL instance.
DATABASE_URL=postgresql://user:password@localhost:5432/smart_ticket_router

# OpenAI API key used for GPT-4.1 ticket classification calls.
# Get one at https://platform.openai.com/api-keys — never commit a real key.
OPENAI_API_KEY=sk-...

# Admin login credentials (single hardcoded admin account, no users table).
# Change these before deploying anywhere real.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Secret used to sign admin JWTs. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-random-secret
JWT_EXPIRE_MINUTES=60
